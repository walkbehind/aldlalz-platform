// Aldlalz — database schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum UserRole {
  USER
  OWNER
  BROKER
  OFFICE
  ADMIN
  SUPERADMIN
}

enum ListingType {
  SALE
  RENT
  BOOKING
  PROJECT
  ENTERTAINMENT
}

enum PropertyType {
  APARTMENT
  VILLA
  HOUSE
  DUPLEX
  CHALET
  OFFICE
  SHOP
  WAREHOUSE
  LAND
  BUILDING
  OTHER
}

enum KuwaitGovernorate {
  CAPITAL
  HAWALLI
  FARWANIYA
  AHMADI
  JAHRA
  MUBARAK_AL_KABEER
}

enum ListingStatus {
  AVAILABLE
  SOLD
  RENTED
  BOOKED
  NEGOTIATING
  UNDER_REVIEW
}

enum AdminStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PackageTarget {
  USER
  OFFICE
}

// ─── Auth.js ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?

  nameAr String?
  nameEn String?
  phone  String? @unique
  role   UserRole @default(USER)

  langPreference String @default("ar")
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  listings Listing[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Listings ────────────────────────────────────────────

model Listing {
  id      String @id @default(cuid())
  ownerId String

  listingType  ListingType
  propertyType PropertyType @default(APARTMENT)

  titleAr       String
  titleEn       String?
  descriptionAr String? @db.Text
  descriptionEn String? @db.Text

  priceKwd Decimal @db.Decimal(12, 3)

  governorate KuwaitGovernorate
  area        String
  paciNumber  String?

  bedrooms  Int?
  bathrooms Int?
  parking   Int?
  sizeM2    Decimal? @db.Decimal(10, 2)

  listingStatus ListingStatus @default(AVAILABLE)
  adminStatus   AdminStatus   @default(PENDING)
  isDraft       Boolean       @default(true)
  rejectionReason String?     @db.Text

  viewCount Int @default(0)

  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  addressLine String?

  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images ListingImage[]

  @@index([ownerId])
  @@index([listingType])
  @@index([propertyType])
  @@index([governorate])
  @@index([area])
  @@index([listingStatus])
  @@index([adminStatus])
  @@index([isDraft])
  @@index([priceKwd])
  @@index([bedrooms])
  @@index([isFeatured])
  @@map("listings")
}

model ListingImage {
  id          String @id @default(cuid())
  listingId   String

  url         String
  storagePath String
  sortOrder   Int    @default(0)
  isCover     Boolean @default(false)

  width     Int?
  height    Int?
  sizeBytes Int?
  mimeType  String @default("image/webp")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, sortOrder])
  @@index([listingId, isCover])
  @@map("listing_images")
}

model Package {
  id String @id @default(cuid())

  nameAr        String
  nameEn        String?
  descriptionAr String? @db.Text
  descriptionEn String? @db.Text

  target       PackageTarget @default(USER)
  tier         Int           @default(1)
  maxListings  Int           @default(5)
  durationDays Int           @default(30)
  priceKwd     Decimal       @db.Decimal(12, 3)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("packages")
}
