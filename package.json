{
  "name": "aldlalz",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@aldlalz/web",
    "build": "npm run db:generate:ci && npm run build --workspace=@aldlalz/web",
    "build:vercel": "npm run db:generate:ci && npm run db:migrate:deploy:ci && npm run build --workspace=@aldlalz/web && node scripts/sync-prisma-vercel.mjs",
    "lint": "npm run lint --workspace=@aldlalz/web",
    "postinstall": "prisma generate --schema=packages/database/prisma/schema.prisma || true",
    "db:generate": "dotenv -e .env.local -- prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:generate:ci": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:push": "dotenv -e .env.local -- prisma db push --schema=packages/database/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev --schema=packages/database/prisma/schema.prisma",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy --schema=packages/database/prisma/schema.prisma",
    "db:migrate:deploy:ci": "prisma migrate deploy --schema=packages/database/prisma/schema.prisma",
    "db:studio": "dotenv -e .env.local -- prisma studio --schema=packages/database/prisma/schema.prisma",
    "db:seed": "dotenv -e .env.local -- npm run db:seed --workspace=@aldlalz/database",
    "db:verify": "dotenv -e .env.local -- node scripts/verify-db.mjs",
    "db:sync-env": "node scripts/sync-supabase-env.mjs",
    "db:find-region": "node scripts/find-supabase-region.mjs",
    "storage:setup": "node scripts/setup-storage-env.mjs",
    "storage:sync": "node scripts/sync-storage-env.mjs",
    "storage:check": "node scripts/check-storage.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv-cli": "^8.0.0",
    "pg": "^8.21.0",
    "prisma": "^6.19.0"
  }
}
