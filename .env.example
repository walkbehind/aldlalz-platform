# ─── Copy to .env.local (repo root + apps/web/.env.local) ─
# Never commit .env or .env.local

# ─── Supabase PostgreSQL (ap-northeast-1 example) ─────────
# Copy exact URIs from Supabase → Settings → Database → Connection string

# Transaction pooler — app runtime (port 6543)
# connection_limit=1 is required on Vercel/serverless with PgBouncer
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Session pooler — Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# If you only have the direct host URL, run: npm run db:sync-env

# ─── Auth (Auth.js) ───────────────────────────────────────
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Supabase Storage (Phase 3) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Google Maps (Phase 3) ─────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── AI translation (listing bilingual fields) ─────────────
# Set at least one provider key. TRANSLATION_PROVIDER=auto tries all configured keys.
TRANSLATION_PROVIDER="auto"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
# Optional model overrides:
# OPENAI_TRANSLATION_MODEL="gpt-4o-mini"
# ANTHROPIC_TRANSLATION_MODEL="claude-3-5-haiku-20241022"
# GOOGLE_TRANSLATION_MODEL="gemini-2.0-flash"

# ─── Seed (local only) ────────────────────────────────────
SEED_ADMIN_EMAIL="admin@aldlalz.com"
SEED_ADMIN_PASSWORD="Admin123!"

# ─── Vercel production ────────────────────────────────────
# Set the same DATABASE_URL, DIRECT_URL, AUTH_SECRET, AUTH_URL,
# NEXT_PUBLIC_APP_URL in Vercel → Project → Settings → Environment Variables
