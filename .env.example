# ─── Copy to .env (repo root) AND apps/web/.env.local ─────
# Never commit .env or .env.local — they are gitignored.

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/aldlalz?schema=public"

# ─── Auth (Auth.js) ───────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Seed (local only) ────────────────────────────────────
SEED_ADMIN_EMAIL="admin@aldlalz.com"
SEED_ADMIN_PASSWORD="Admin123!"

